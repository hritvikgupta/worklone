# Workflow Engine — Environment Variables
# Copy this to .env and fill in your values

# ─── LLM (Required) ───
OPENROUTER_API_KEY=sk-or-...

# ─── Deployment Mode ───
# self_hosted: users save their own OAuth client ID/secret per integration
# cloud: server uses PROVIDER_* env credentials (managed platform mode)
DEPLOYMENT_MODE=self_hosted

# ─── Alternative LLM Providers (Optional) ───
# NVIDIA NIM API - Get key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...

# ─── Integrations (Optional) ───
SLACK_BOT_TOKEN=xoxb-...
GMAIL_ACCESS_TOKEN=ya29....

# ─── Web Search / Extract Providers (Optional) ───
# Used by web_search/web_extract tools.
FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_API_URL=http://localhost:3002  # Optional self-hosted Firecrawl URL
TAVILY_API_KEY=tvly-...
EXA_API_KEY=exa-...

# ─── OAuth Client Credentials (Cloud Mode) ───
# Set these only when DEPLOYMENT_MODE=cloud.
# For self_hosted mode, users provide and store their own keys in Integrations UI.
# PROVIDER_GOOGLE_CLIENT_ID=
# PROVIDER_GOOGLE_CLIENT_SECRET=
# PROVIDER_SLACK_CLIENT_ID=
# PROVIDER_SLACK_CLIENT_SECRET=
# PROVIDER_GITHUB_CLIENT_ID=
# PROVIDER_GITHUB_CLIENT_SECRET=
# PROVIDER_NOTION_CLIENT_ID=
# PROVIDER_NOTION_CLIENT_SECRET=
# PROVIDER_JIRA_CLIENT_ID=
# PROVIDER_JIRA_CLIENT_SECRET=

# ─── Database ───
WORKFLOW_DB=workflows.db

# ─── Server ───
PORT=8002
HOST=0.0.0.0

# ─── Redis / Dispatch ───
# Local dev: redis://localhost:6379/0
# Docker compose backend overrides this to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Worker ───
WORKER_POLL_INTERVAL=5
WORKER_MAX_CONCURRENT=10
